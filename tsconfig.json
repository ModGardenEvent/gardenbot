{
    "compilerOptions": {
        "target": "es2022",
        "module": "es2022",
        "rootDir": "./src",
        "outDir": "./dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "moduleResolution": "node",
        "skipDefaultLibCheck": true,
        "skipLibCheck": true,
        "strict": true,
        "incremental": true,
        "sourceMap": true
    },
    "include": [
        "./src"
    ]
}